# ============================================================
# Jarvis V3 — Configuration
# Copier ce fichier en .env et remplir les valeurs réelles.
# Ne jamais commiter .env.
# ============================================================

# ── Identité ──────────────────────────────────────────────────
USER_FIRSTNAME=Barth
# Bio courte (optionnelle) injectée dans le moteur proactif. Vide = omise.
# Ex : USER_PROFILE=entrepreneur tech, YouTuber hardware, Lyon
USER_PROFILE=

# ── Serveur ───────────────────────────────────────────────────
# HOST=127.0.0.1 par défaut (localhost uniquement, valeur recommandée).
# Pour exposer hors de la machine (Tailscale, VPS), décommenter la ligne
# ci-dessous ET activer API_AUTH_ENABLED=true (section Sécurité réseau).
# HOST=0.0.0.0
PORT=8000
# "development" | "production"
ENVIRONMENT=development
LOG_LEVEL=INFO

# ── Sécurité réseau ───────────────────────────────────────────
# Par défaut : auth désactivée, usage local uniquement (HOST=127.0.0.1).
# Pour un accès distant sécurisé (Tailscale, VPS) :
#   1. Générer un token : openssl rand -hex 32
#   2. Renseigner API_TOKEN avec la valeur générée
#   3. Activer API_AUTH_ENABLED=true
#   4. Décommenter HOST=0.0.0.0 ci-dessus
#   5. Configurer CORS_ALLOW_ORIGINS avec les origines autorisées
API_AUTH_ENABLED=false
API_TOKEN=
# Origines CORS autorisées (format JSON ou virgule-séparée)
# Ex. pour Tailscale : CORS_ALLOW_ORIGINS=["http://mon-pc.tailscale:8000"]
CORS_ALLOW_ORIGINS=[]

# ── LLM ───────────────────────────────────────────────────────
# "api" pour Anthropic/OpenAI/Mistral, "local" pour Ollama
LLM_PROVIDER=api
# Backend principal (chat texte, vocal in-house, tâches background).
# "anthropic" | "openai" | "mistral"
#
# Une seule clé est requise : celle du backend choisi.
#   API_BACKEND=anthropic  -> ANTHROPIC_API_KEY obligatoire
#   API_BACKEND=openai     -> OPENAI_API_KEY obligatoire (Anthropic peut rester en exemple)
#   API_BACKEND=mistral    -> MISTRAL_API_KEY obligatoire
# Les clés des autres backends peuvent rester à leur valeur d'exemple.
API_BACKEND=anthropic
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6
OPENAI_MODEL=gpt-4o-mini
# Modèle Anthropic utilisé par le vocal in-house QUAND API_BACKEND=anthropic
# (sur les autres backends, le vocal utilise le modèle standard du backend).
VOICE_ANTHROPIC_MODEL=claude-haiku-4-5-20251001
# Pipeline vocal LiveKit temps réel (process séparé) : suit aussi API_BACKEND.
# Optionnel — surcharge le modèle LLM du pipeline LiveKit, quel que soit le backend.
# Si API_BACKEND n'est pas géré côté LiveKit, fallback Gemini (GOOGLE_API_KEY requis).
# VOICE_LLM_MODEL=gemini-2.5-flash

# ── OpenAI ────────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-...

# ── Google / Gemini ───────────────────────────────────────────
# Clé sur ai.google.dev — aussi utilisée pour Calendar/Drive
GOOGLE_API_KEY=AIza...

# OAuth2 Gmail/Calendar — app type « Web » sur console.cloud.google.com.
# Redirect URIs à enregistrer : http://127.0.0.1:8000/api/google/callback/gmail
# et http://127.0.0.1:8000/api/google/callback/calendar
# Renseignés ici (ou via Mission Control → Capacités → Gmail), le fichier
# config/google_credentials.json est régénéré automatiquement.
GOOGLE_CLIENT_ID=...
GOOGLE_CLIENT_SECRET=...

# ── Ollama (LLM local) ────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:8b

# ── Mistral (optionnel) ───────────────────────────────────────
MISTRAL_API_KEY=...
MISTRAL_MODEL=mistral-large-latest

# ── TTS / Voix ────────────────────────────────────────────────
# "piper" (local) | "elevenlabs" | "gemini"
TTS_PROVIDER=elevenlabs
ELEVENLABS_API_KEY=sk_...
ELEVENLABS_VOICE_ID=5l4ttmr4SKNgi0HnOelT
ELEVENLABS_MODEL=eleven_flash_v2_5
# Gemini TTS (si TTS_PROVIDER=gemini) — auth via GOOGLE_API_KEY ci-dessus.
# Modèle : gemini-2.5-flash-preview-tts | gemini-2.5-pro-preview-tts
# Voix (30 dispo) : Kore, Puck, Charon, Aoede, Zephyr, Fenrir, Leda…
GEMINI_TTS_MODEL=gemini-2.5-flash-preview-tts
GEMINI_TTS_VOICE=Kore
# Mode québécois
QUEBEC_MODE=false
QUEBEC_VOICE_ID=RBhYSNMNu6b2CGZ9Fn1W

# ── STT (pipeline vocal LiveKit) ──────────────────────────────
# Backend reconnaissance vocale : "deepgram" (cloud, défaut) | "openai" (Whisper
# cloud) | "google" (Cloud Speech, service account). "whisper" local à venir.
#   deepgram -> DEEPGRAM_API_KEY   |   openai -> OPENAI_API_KEY
#   google   -> GOOGLE_APPLICATION_CREDENTIALS (service account Speech-to-Text)
STT_PROVIDER=deepgram
# Whisper local (si STT_PROVIDER=whisper) : "tiny" | "small" | "medium" | "large"
WHISPER_MODEL=tiny
DEEPGRAM_API_KEY=...

# ── LiveKit (pipeline vocal temps réel) ───────────────────────
# Créer un projet sur cloud.livekit.io
LIVEKIT_URL=wss://ton-projet.livekit.cloud
LIVEKIT_API_KEY=APIxxx...
LIVEKIT_API_SECRET=xxx...

# ── Notion ────────────────────────────────────────────────────
NOTION_TOKEN=ntn_...
NOTION_PAGE_ID=...

# ── Spotify ───────────────────────────────────────────────────
# Crée une app sur https://developer.spotify.com/dashboard
# Redirect URI : http://127.0.0.1:8000/api/spotify/callback
# (ou colle ces deux valeurs via Mission Control → Capacités → Spotify)
SPOTIFY_CLIENT_ID=...
SPOTIFY_CLIENT_SECRET=...

# ── Deezer ────────────────────────────────────────────────────
# Crée une app sur https://developers.deezer.com/myapps
# Redirect URL après authentification : http://127.0.0.1:8000/api/deezer/callback
# (ou colle ces deux valeurs via Mission Control → Capacités → Deezer)
DEEZER_APP_ID=...
DEEZER_APP_SECRET=...

# ── Cartographie ──────────────────────────────────────────────
MAPBOX_TOKEN=pk.eyJ1...
MAPTILER_KEY=...

# ── Vision & Reconnaissance faciale ───────────────────────────
VISION_OBJECT_DETECTION=false
VISION_WEBCAM_INDEX=0
VISION_YOLO_CONFIDENCE=0.5
FACE_RECOGNITION_ENABLED=true
FACE_RECOGNITION_THRESHOLD=0.45

# ── Wake Up (séquence démarrage) ──────────────────────────────
WAKEUP_ENABLED=false

# ── Clap Detection ────────────────────────────────────────────
CLAP_DETECTION_ENABLED=false
CLAP_AMPLITUDE_THRESHOLD=0.35

# ── Docker (sandbox agent) ────────────────────────────────────
DOCKER_ENABLED=false
DOCKER_BASE_IMAGE=python:3.11-slim
DOCKER_MEMORY_LIMIT=512m
DOCKER_CPU_LIMIT=1.0
DOCKER_TIMEOUT_SECONDS=30

# ── Imprimante 3D (BambuLab) ──────────────────────────────────
PRINTER_IP=192.168.1.x
PRINTER_SERIAL=...
PRINTER_ACCESS_CODE=...

# ── Fusion 360 MCP ────────────────────────────────────────────
FUSION_ENABLED=false
FUSION_MCP_URL=http://127.0.0.1:27182/mcp

# ── Proactif (briefing / rappels) ─────────────────────────────
BRIEFING_HOUR=7
CALENDAR_REMINDER_MINUTES=15
PROACTIVE_LAT=48.85
PROACTIVE_LON=2.35
PROACTIVE_CITY=Paris

# ── Musique ───────────────────────────────────────────────────
# "spotify" | "deezer" | "local"
MUSIC_PROVIDER=spotify

# ── YouTube ───────────────────────────────────────────────────
YOUTUBE_API_KEY=AIza...
YOUTUBE_CHANNEL_ID=UCxx...

# ── GitHub ────────────────────────────────────────────────────
GITHUB_TOKEN=ghp_...
GITHUB_REPO=https://github.com/ton-user/ton-repo

# ── AISstream (trafic maritime) ───────────────────────────────
# Clé sur aisstream.io — utilisée par le World Monitor
AISSTREAM_KEY=...

# ── Telegram (accès mobile) ───────────────────────────────────
# 1. @BotFather → /newbot → récupère le token
# 2. @userinfobot → envoie un message → récupère ton user ID
TELEGRAM_BOT_TOKEN=
TELEGRAM_OWNER_ID=
TELEGRAM_ENABLED=false

# ── Messaging Gateway (multi-plateforme) ─────────
# Passer à true pour activer le gateway unifié (session persistée cross-messages).
# false = mode legacy Telegram seul (comportement d'origine).
MESSAGING_GATEWAY_ENABLED=true

# ── Discord ───────────────────────────────────────────────────
# 1. discord.com/developers → New Application → Bot → Token
# 2. Activer "Message Content Intent" dans les paramètres du bot
# 3. Installer discord.py : uv add discord.py
DISCORD_BOT_TOKEN=
DISCORD_OWNER_ID=
DISCORD_ENABLED=false
