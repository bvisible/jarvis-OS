# ============================================================
# Jarvis V3 — Configuration
# Copier ce fichier en .env et remplir les valeurs réelles.
# Ne jamais commiter .env.
# ============================================================

# ── Identité ──────────────────────────────────────────────────
USER_FIRSTNAME=Barth

# ── Serveur ───────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
# "development" | "production"
ENVIRONMENT=development
LOG_LEVEL=INFO

# ── LLM ───────────────────────────────────────────────────────
# "api" pour Anthropic/OpenAI/Gemini, "local" pour Ollama
LLM_PROVIDER=api
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6
# Modèle utilisé dans le pipeline vocal (peut différer du chat)
VOICE_ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# ── OpenAI ────────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-...

# ── Google / Gemini ───────────────────────────────────────────
# Clé sur ai.google.dev — aussi utilisée pour Calendar/Drive
GOOGLE_API_KEY=AIza...

# ── Ollama (LLM local) ────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:8b

# ── Mistral (optionnel) ───────────────────────────────────────
MISTRAL_API_KEY=...
MISTRAL_MODEL=mistral-large-latest

# ── TTS / Voix ────────────────────────────────────────────────
# "elevenlabs" | "local" | "deepgram"
TTS_PROVIDER=elevenlabs
ELEVENLABS_API_KEY=sk_...
ELEVENLABS_VOICE_ID=...
ELEVENLABS_MODEL=eleven_flash_v2_5
# Mode québécois
QUEBEC_MODE=false
QUEBEC_VOICE_ID=...

# ── STT ───────────────────────────────────────────────────────
# Whisper local : "tiny" | "small" | "medium" | "large"
WHISPER_MODEL=tiny
DEEPGRAM_API_KEY=...

# ── LiveKit (pipeline vocal temps réel) ───────────────────────
# Créer un projet sur cloud.livekit.io
LIVEKIT_URL=wss://ton-projet.livekit.cloud
LIVEKIT_API_KEY=APIxxx...
LIVEKIT_API_SECRET=xxx...

# ── Notion ────────────────────────────────────────────────────
NOTION_TOKEN=ntn_...
NOTION_PAGE_ID=...

# ── Spotify ───────────────────────────────────────────────────
SPOTIFY_CLIENT_ID=...
SPOTIFY_CLIENT_SECRET=...

# ── Cartographie ──────────────────────────────────────────────
MAPBOX_TOKEN=pk.eyJ1...
MAPTILER_KEY=...

# ── Vision & Reconnaissance faciale ───────────────────────────
VISION_OBJECT_DETECTION=false
VISION_WEBCAM_INDEX=0
VISION_YOLO_CONFIDENCE=0.5
FACE_RECOGNITION_ENABLED=false
FACE_RECOGNITION_THRESHOLD=0.45

# ── Wake Up (séquence démarrage) ──────────────────────────────
WAKEUP_ENABLED=false

# ── Clap Detection ────────────────────────────────────────────
CLAP_DETECTION_ENABLED=false
CLAP_AMPLITUDE_THRESHOLD=0.35

# ── Docker (sandbox agent) ────────────────────────────────────
DOCKER_ENABLED=false
DOCKER_BASE_IMAGE=python:3.11-slim
DOCKER_MEMORY_LIMIT=512m
DOCKER_CPU_LIMIT=1.0
DOCKER_TIMEOUT_SECONDS=30

# ── Imprimante 3D (BambuLab) ──────────────────────────────────
PRINTER_IP=192.168.1.x
PRINTER_SERIAL=...
PRINTER_ACCESS_CODE=...

# ── Fusion 360 MCP ────────────────────────────────────────────
FUSION_ENABLED=false
FUSION_MCP_URL=http://127.0.0.1:27182/mcp

# ── Proactif (briefing / rappels) ─────────────────────────────
BRIEFING_HOUR=7
CALENDAR_REMINDER_MINUTES=15
PROACTIVE_LAT=48.85
PROACTIVE_LON=2.35
PROACTIVE_CITY=Paris
